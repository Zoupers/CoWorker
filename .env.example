# 可选：Coworker 可以不创建 .env 直接启动，再通过 /admin 首次初始化向导配置。
# 无人值守部署也可以在这里预先配置 LLM API Keys。
# 实例级运行时语言；控制 Prompt、工具说明和系统通知，与 Web/Desktop 界面语言独立。
# 支持 zh-CN / en 及常见别名。修改后需安全重启。
I18N__LOCALE=zh-CN

LLM__ANTHROPIC_API_KEY=
LLM__ANTHROPIC_BASE_URL=
LLM__OPENAI_API_KEY=
LLM__OPENAI_BASE_URL=
LLM__DEEPSEEK_API_KEY=
LLM__DEEPSEEK_BASE_URL=
LLM__QWEN_API_KEY=
LLM__QWEN_BASE_URL=
LLM__ZHIPU_API_KEY=
LLM__ZHIPU_BASE_URL=
LLM__MINIMAX_API_KEY=
LLM__MINIMAX_BASE_URL=

# 命名 provider 列表文件（可选）。上面的扁平字段仍然有效，会自动并入为 name==type 的默认实例；
# 若需要同一类型的多个实例（例如多个智谱 key 面向多用户），在此文件里按 name 列举即可。
# 文件不存在则忽略。格式见 providers.json.example。
LLM__PROVIDERS_FILE=providers.json
# 在线修改 summary / fallbacks / vision 后写入的运行态覆盖文件；启动时会覆盖 .env 中同名模型配置。
LLM__RUNTIME_CONFIG_FILE=data/model_runtime_config.json

# LLM Settings
LLM__DEFAULT_PROVIDER=deepseek
LLM__DEFAULT_MODEL=deepseek-v4-pro
LLM__MAX_TOKENS=8192

# 摘要/压缩专用模型。留空则沿用当前主线模型；只填 SUMMARY_MODEL 时复用当前 provider；
# 只填 SUMMARY_PROVIDER 时使用该 provider 在 providers.json 中的 default_model。
# LLM__SUMMARY_PROVIDER=deepseek
# LLM__SUMMARY_MODEL=deepseek-v4-flash
# LLM__SUMMARY_THINKING=false

# 主模型调用失败后的有序降级链（JSON 数组）。每项 "providerName" 或 "providerName/modelId"，
# 省略 modelId 时用该 provider 的 default_model。降级后停在备用模型，等手动 switch_model 切回。
# LLM__FALLBACKS=["zhipu-userB","deepseek/deepseek-chat"]

# 视觉分析工具专用模型（纯文本模型遇到图片时调用，留空时 analyze_image 会提示先配置）
# LLM__VISION_PROVIDER=anthropic
# LLM__VISION_MODEL=claude-sonnet-4-6
# 保持默认思考模式；设为 false 可降低视觉分析延迟和成本（需 provider/model 支持）。
# LLM__VISION_THINKING=false

# Memory Settings
MEMORY__DB_PATH=data/memory
MEMORY__SHORT_TERM_MAX_TOKENS=80000
MEMORY__COMPRESS_THRESHOLD=0.55

# 多分辨率「记忆树」：短期记忆压缩不再塌缩成单条摘要，而是把最老切片提升为树叶、
# 按时间尺度二进制级联合并成多分辨率脊柱（近期全细节、越久越粗），让 Agent 对更大
# 时间尺度所做的事保持把握。关闭则回退旧的单锚点压缩。
MEMORY__TREE_ENABLED=true
MEMORY__TREE_TAIL_FRACTION=0.70          # 尾部保留原始消息的 token 占比（其余可被提升进树）
MEMORY__TREE_SPINE_CAP_FRACTION=0.30     # 脊柱 token 上限占比；唯一预算旋钮，节点预算/K 均由它导出
MEMORY__TREE_BACKFILL_MAX_LEAVES=64      # `--backfill-tree` 一次性回溯历史生成的叶子数上限
MEMORY__TREE_BACKFILL_CONCURRENCY=5      # 回溯时叶子摘要/归约合并的并发上限
MEMORY__TREE_MERGE_REACH_DEPTH=2         # 高层合并向下「够细」层数：2=低两层（默认，减轻 telephone）、1=仅直接子摘要

# 自动回忆：收到新消息时自动检索相关长期记忆并注入上下文
MEMORY__AUTO_RECALL_ENABLED=true
MEMORY__AUTO_RECALL_RELEVANCE_THRESHOLD=0.5
MEMORY__AUTO_RECALL_LIMIT=5

# 最近活动索引：query_memory(query=...) 会同时检索最近 N 天交互日志和 mem0 长期记忆。
# 超长 tool_result 会按当前 embedder 的 tokenizer token 滑窗切片；message_tick 不入索引。
MEMORY__RECENT_ACTIVITY_ENABLED=true
MEMORY__RECENT_ACTIVITY_DAYS=7
MEMORY__RECENT_ACTIVITY_CHUNK_TOKENS=120
MEMORY__RECENT_ACTIVITY_OVERLAP_TOKENS=24
MEMORY__RECENT_ACTIVITY_QUERY_LIMIT=5
MEMORY__RECENT_ACTIVITY_AUTO_RECALL_ENABLED=true
MEMORY__RECENT_ACTIVITY_AUTO_RECALL_LIMIT=2
MEMORY__RECENT_ACTIVITY_AUTO_RECALL_RELEVANCE_THRESHOLD=0.72

# mem0 使用的 LLM（用于记忆提取/去重推断，建议用便宜模型）
# provider 可选：anthropic / openai / deepseek / qwen / zhipu
MEMORY__MEM0_LLM_PROVIDER=deepseek
MEMORY__MEM0_LLM_MODEL=deepseek-v4-flash

# mem0 使用的嵌入模型（HuggingFace sentence-transformers）。已有记忆使用同一向量空间，
# 当前没有面向用户的自动迁移命令，不要在保留既有数据时直接切换模型。
MEMORY__MEM0_EMBEDDER_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Agent Settings
AGENT__INBOX_DIR=data/inbox
AGENT__OUTBOX_DIR=data/outbox
AGENT__IDENTITY_DIR=data/identity
AGENT__LOGS_DIR=data/logs
# interactions.jsonl reaches this size before it is moved to interactions-000001.jsonl.
# Set to 0 to keep a single file (not recommended for long-running instances).
AGENT__INTERACTION_LOG_ROTATION_BYTES=10485760
AGENT__IDLE_SLEEP_SECONDS=30
AGENT__INBOX_POLL_INTERVAL=2.0
AGENT__TICK=true
# passive 模式：模型 sleep 不设 idle 超时，只等外部事件唤醒（关闭周期性 tick 自驱）。
# 模型也可主动调用 sleep(0) 进入同样的被动等待。运行时可在管理控制台热切换。
AGENT__PASSIVE_MODE=false
AGENT__IMAGE_MAX_DIMENSION=960
# 给发送给模型的 user 消息正文加上时间戳前缀，如 [2026-06-02 14:30:05 周一]（默认开启）
AGENT__MESSAGE_TIME_PREFIX=true
# 泡泡思考：允许模型并行分叉子任务（默认开启）
AGENT__BUBBLE_THINKING=true
AGENT__BUBBLE_MAX_CONCURRENT=5
# participant_id 按大小写敏感的整串 glob 匹配；命中时说明泡泡接管/结束（含 Bubble ID），并标识泡泡直接回复。无通配符即精确匹配，[] 关闭默认匹配。
# 默认透明企微和 Desktop local actor；coworker-desktop 的 claude/codex actor 不匹配。
AGENT__BUBBLE_HANDOFF_TRANSPARENCY_PARTICIPANT_MATCHES=["wecom:*","coworker-desktop:*:local:*"]
# 通用 websocket / sse 长连接默认透明；设为 [] 可关闭。Desktop actor 未命中上方 participant glob 时，不会被此通用规则兜底命中。
AGENT__BUBBLE_HANDOFF_TRANSPARENCY_STREAM_TRANSPORTS=["websocket","sse"]

# 潜意识思考：系统自动触发的后台自省（默认开启）
# 各模式的触发节奏写在 `.coworker/subconscious/*/MODE.md`；这里只保留总开关和通用兜底项。
AGENT__SUBCONSCIOUS_THINKING=true
AGENT__SUBCONSCIOUS_SUMMARIZE_BEFORE_COMPRESS=true
AGENT__SUBCONSCIOUS_MAX_CYCLES=5

# API Settings
# Loopback is the safe default. Set this explicitly only when a trusted
# reverse proxy/firewall is in front of the API.
API__HOST=127.0.0.1
API__PORT=8000
# JSON list of browser origins allowed to call the API. Keep this limited to
# known frontends; [] disables browser cross-origin requests.
API__CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# 管理控制台（/admin）。令牌只用于 Bearer 鉴权，页面不会回显；托管覆盖文件优先于 .env。
ADMIN__TOKEN=
ADMIN__CONFIG_FILE=data/admin_config.json

# Desktop auto-update release storage and admin API token.
# 管理接口需要 Authorization: Bearer <token>；更新查询和 asset 下载不需要 token。
DESKTOP_UPDATES__DIR=data/desktop_updates
DESKTOP_UPDATES__ADMIN_TOKEN=

# 企业微信智能机器人（长连接模式）
WECOM__ENABLED=false
WECOM__BOT_ID=
WECOM__SECRET=
# 可选；不填走 SDK 默认 wss://openws.work.weixin.qq.com
WECOM__WS_URL=
# CoWorker Desktop communication transport. Development mode disables both
# bearer authentication and HTTPS enforcement; leave it false for normal use.
API__DEVELOPMENT_MODE=false
# Required by Desktop in production mode. Use a long random value.
API__COMMUNICATION_TOKEN=
API__DELIVERY_DB_PATH=data/coworker_desktop/delivery.sqlite3
